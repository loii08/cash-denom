rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: transactions
    // Document ID: auto-generated
    // Fields:
    //   - date: timestamp (required) - The date and time the transaction was saved.
    //   - breakdown: map (required) - Quantity of each denomination.
    //     - 1000: integer
    //     - 500: integer
    //     - 200: integer
    //     - 100: integer
    //     - 50: integer
    //     - 20: integer
    //     - 10: integer
    //     - 5: integer
    //     - 1: integer
    //   - total: number (required) - The total amount calculated from the breakdown.
    //   - uid: string (required) - The user ID who owns this transaction.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidTransaction(data) {
      return data.date is timestamp &&
             data.breakdown is map &&
             data.total is number &&
             data.uid is string &&
             data.uid == request.auth.uid;
    }

    function isValidActivityLog(data) {
      return data.action in ['CREATE', 'UPDATE', 'DELETE'] &&
             data.timestamp is timestamp &&
             data.details is map &&
             data.uid is string &&
             data.uid == request.auth.uid;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((request.auth.token.email == "kenneth.irvinb@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && request.query.where[0].value == request.auth.uid;
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isValidTransaction(request.resource.data) && (isDocOwner() || isAdmin()) && request.resource.data.uid == resource.data.uid;
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /activityLogs/{logId} {
      allow read: if isAuthenticated() && request.query.where[0].value == request.auth.uid;
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidActivityLog(request.resource.data) && uidUnchanged();
      allow update, delete: if false; // Logs should be immutable
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow create, update: if isAuthenticated() && isOwner(userId) && (!('role' in request.resource.data) || isAdmin());
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
