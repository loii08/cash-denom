rules_version = '2';

service cloud.firestore {
  // ===============================================================
  // Helper Functions
  // ===============================================================
  function isAuthenticated() {
    return request.auth != null;
  }

  function isDocOwner() {
    return isAuthenticated() && request.auth.uid == resource.data.uid;
  }

  function uidUnchanged() {
    return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
  }

  function isValidTransaction(data) {
    return data.date is timestamp &&
           data.breakdown is map &&
           data.total is number &&
           data.uid is string &&
           data.uid == request.auth.uid;
  }

  function isValidActivityLog(data) {
    return data.action in ['CREATE', 'UPDATE', 'DELETE'] &&
           data.timestamp is timestamp &&
           data.details is map &&
           data.uid is string &&
           data.uid == request.auth.uid;
  }

  function isAdmin() {
    return isAuthenticated() &&
      request.auth.token.email == "kenneth.irvinb@gmail.com" && 
      request.auth.token.email_verified == true;
  }

  // ===============================================================
  // Rules
  // ===============================================================
  
  match /databases/{database}/documents {
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && request.query.where[0].value == request.auth.uid;
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data) && uidUnchanged();
      allow update: if isAuthenticated() && isValidTransaction(request.resource.data) && (isDocOwner() || isAdmin()) && request.resource.data.uid == resource.data.uid;
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /activityLogs/{logId} {
      allow read: if isAuthenticated() && request.query.where[0].value == request.auth.uid;
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidActivityLog(request.resource.data) && uidUnchanged();
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
    }

    match /test/connection {
      allow read: if true;
    }
  }
}
