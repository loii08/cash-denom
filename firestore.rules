rules_version = '2';

// Deployed: v1.2.2 - Fixed walletMembers update/delete rules
service cloud.firestore {
  // ===============================================================
  // Helper Functions
  // ===============================================================
  function isAuthenticated() {
    return request.auth != null;
  }

  function isDocOwner() {
    return isAuthenticated() && request.auth.uid == resource.data.uid;
  }

  function uidUnchanged() {
    return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
  }

  function isValidTransaction(data) {
    return data.date is timestamp &&
           data.breakdown is map &&
           data.total is number &&
           data.uid is string;
  }

  function isValidActivityLog(data) {
    return data.action in ['CREATE', 'UPDATE', 'DELETE'] &&
           data.timestamp is timestamp &&
           data.details is map &&
           data.uid is string;
  }

  function isValidExpense(data) {
    return data.date is timestamp &&
           data.amount is number &&
           data.amount > 0 &&
           data.description is string &&
           data.uid is string;
  }

  function isValidSharedAccess(data) {
    return data.ownerId is string &&
           data.sharedWithId is string &&
           data.sharedWithEmail is string &&
           data.role in ['owner', 'editor', 'viewer'] &&
           data.createdAt is timestamp;
  }

  function isAdmin() {
    return isAuthenticated() &&
      request.auth.token.email == "kenneth.irvinb@gmail.com" && 
      request.auth.token.email_verified == true;
  }

  // Get the ownerId for a given document
  function getDocOwnerId(docId, collection) {
    return get(/databases/$(database)/documents/$(collection)/$(docId)).data.uid;
  }

  // Check if current user has shared access to owner's data
  function hasSharedAccess(ownerId, requiredRole) {
    return isAuthenticated() &&
      exists(/databases/$(database)/documents/sharedAccess/$(ownerId + '_' + request.auth.uid)) &&
      get(/databases/$(database)/documents/sharedAccess/$(ownerId + '_' + request.auth.uid)).data.sharedWithId == request.auth.uid &&
      (requiredRole == 'viewer' ||
       (requiredRole == 'editor' && get(/databases/$(database)/documents/sharedAccess/$(ownerId + '_' + request.auth.uid)).data.role in ['editor', 'owner']) ||
       (requiredRole == 'owner' && get(/databases/$(database)/documents/sharedAccess/$(ownerId + '_' + request.auth.uid)).data.role == 'owner'));
  }

  // Check if user can read a document (owner or shared viewer/editor)
  function canReadDocument(docOwnerId) {
    return isAuthenticated() && (request.auth.uid == docOwnerId || hasSharedAccess(docOwnerId, 'viewer'));
  }

  // Check if user can modify a document (owner or shared editor)
  function canModifyDocument(docOwnerId) {
    return isAuthenticated() && (request.auth.uid == docOwnerId || hasSharedAccess(docOwnerId, 'editor'));
  }

  // Check if user is owner of the data
  function isDataOwner(docOwnerId) {
    return isAuthenticated() && request.auth.uid == docOwnerId;
  }

  // ===============================================================
  // Rules
  // ===============================================================
  
  match /databases/{database}/documents {
    // Transactions collection
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && canReadDocument(resource.data.uid);
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data) && 
                    (request.resource.data.uid == request.auth.uid || canModifyDocument(request.resource.data.uid));
      allow update: if isAuthenticated() && isValidTransaction(request.resource.data) && 
                    canModifyDocument(resource.data.uid) && 
                    request.resource.data.uid == resource.data.uid &&
                    uidUnchanged() &&
                    // Allow adding walletId during migration
                    (!('walletId' in resource.data) || resource.data.walletId == request.resource.data.walletId);
      allow delete: if isAuthenticated() && canModifyDocument(resource.data.uid);
    }

    // Activity Logs collection
    match /activityLogs/{logId} {
      allow read: if isAuthenticated() && canReadDocument(resource.data.uid);
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidActivityLog(request.resource.data) && 
                    (request.resource.data.uid == request.auth.uid || canModifyDocument(request.resource.data.uid));
      // Allow updates only for adding walletId during migration
      allow update: if isAuthenticated() && 
                    isDataOwner(resource.data.uid) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['walletId']);
      allow delete: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
    }
    // Allow listing users by email (for checking if user exists before sharing)
    match /users/{userId} {
      allow list: if isAuthenticated();
    }

    // Expenses collection
    match /expenses/{expenseId} {
      allow read: if isAuthenticated() && canReadDocument(resource.data.uid);
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && isValidExpense(request.resource.data) &&
                    (request.resource.data.uid == request.auth.uid || canModifyDocument(request.resource.data.uid));
      allow update: if isAuthenticated() && isValidExpense(request.resource.data) && 
                    canModifyDocument(resource.data.uid) && 
                    request.resource.data.uid == resource.data.uid &&
                    uidUnchanged() &&
                    // Allow adding walletId during migration
                    (!('walletId' in resource.data) || resource.data.walletId == request.resource.data.walletId);
      allow delete: if isAuthenticated() && canModifyDocument(resource.data.uid);
    }

    // Shared Access collection - manages sharing permissions
    match /sharedAccess/{accessId} {
      allow read: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.sharedWithId == request.auth.uid ||
        isAdmin()
      );
      allow list: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid || 
        resource.data.sharedWithId == request.auth.uid ||
        isAdmin()
      );
      // Only owner can create sharing records
      allow create: if isAuthenticated() && isValidSharedAccess(request.resource.data) && 
                    request.resource.data.ownerId == request.auth.uid &&
                    request.resource.data.sharedWithId != request.auth.uid;
      // Only owner can update or delete sharing records
      allow update: if isAuthenticated() && isValidSharedAccess(request.resource.data) &&
                    resource.data.ownerId == request.auth.uid &&
                    request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // Wallets collection - multi-wallet support
    match /wallets/{walletId} {
      allow read: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid ||
        isWalletMember(walletId, request.auth.uid)
      );
      allow list: if isAuthenticated() && (
        resource.data.ownerId == request.auth.uid ||
        isWalletMember(walletId, request.auth.uid)
      );
      allow create: if isAuthenticated() && 
                    request.resource.data.ownerId == request.auth.uid &&
                    request.resource.data.keys().hasAll(['name', 'ownerId', 'createdAt']);
      allow update: if isAuthenticated() && 
                    resource.data.ownerId == request.auth.uid &&
                    request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isAuthenticated() && resource.data.ownerId == request.auth.uid;
    }

    // Wallet Members collection - manages wallet sharing
    match /walletMembers/{memberId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        resource.data.userEmail == request.auth.token.email ||
        resource.data.invitedBy == request.auth.uid ||
        isWalletOwner(resource.data.walletId)
      );
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    isWalletOwner(request.resource.data.walletId) &&
                    request.resource.data.keys().hasAll(['walletId', 'userEmail', 'role', 'status', 'invitedBy', 'invitedAt']);
      allow update: if isAuthenticated();
      allow delete: if isAuthenticated() && (
        resource.data.invitedBy == request.auth.uid ||
        resource.data.userId == request.auth.uid ||
        resource.data.userEmail == request.auth.token.email
      );
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        resource.data.toUserId == request.auth.uid ||
        resource.data.fromUserId == request.auth.uid ||
        resource.data.toUserEmail == request.auth.token.email
      );
      allow list: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.fromUserId == request.auth.uid;
      allow update: if isAuthenticated() && 
                    (resource.data.toUserId == request.auth.uid || resource.data.toUserEmail == request.auth.token.email) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if isAuthenticated() && (resource.data.toUserId == request.auth.uid || resource.data.toUserEmail == request.auth.token.email);
    }

    match /test/connection {
      allow read: if true;
    }

    // Helper functions for multi-wallet system
    function isWalletMember(walletId, userId) {
      return exists(/databases/$(database)/documents/walletMembers/$(walletId + '_' + userId)) &&
             get(/databases/$(database)/documents/walletMembers/$(walletId + '_' + userId)).data.userId == userId &&
             get(/databases/$(database)/documents/walletMembers/$(walletId + '_' + userId)).data.status == 'accepted';
    }

    function isWalletOwner(walletId) {
      return get(/databases/$(database)/documents/wallets/$(walletId)).data.ownerId == request.auth.uid;
    }

    function getWalletOwner(walletId) {
      return get(/databases/$(database)/documents/wallets/$(walletId)).data.ownerId;
    }

    function canAccessWallet(walletId, requiredRole) {
      return isWalletOwner(walletId) ||
             (isWalletMember(walletId, request.auth.uid) &&
              (requiredRole == 'viewer' ||
               (requiredRole == 'editor' && 
                get(/databases/$(database)/documents/walletMembers/$(walletId + '_' + request.auth.uid)).data.role in ['editor', 'owner'])));
    }
  }
}
